# @supabase/server (server-side routes, Edge Functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Browser client (same publishable key as SUPABASE_PUBLISHABLE_KEY)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Legacy alias — use SUPABASE_SECRET_KEY instead
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres (for npm run setup:departments-db — optional if you run SQL manually)
# SUPABASE_DB_PASSWORD=
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
