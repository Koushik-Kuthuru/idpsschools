rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Super-admin check: user owns their own doc in super_admin_users.
    // We use get() here only inside rules that are NOT on super_admin_users
    // itself, to avoid circular evaluation.
    function isSuperAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/super_admin_users/$(request.auth.uid));
    }

    // Role doc helpers (used for school-scoped collections)
    function userRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }

    function hasRoleDoc() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }

    function isSchoolMember(schoolId) {
      return isAuthenticated() && hasRoleDoc() && userRole().schoolId == schoolId;
    }

    function isSchoolAdmin(schoolId) {
      return isAuthenticated() && hasRoleDoc()
        && userRole().schoolId == schoolId
        && userRole().role == 'admin';
    }

    // ── super_admin_users ────────────────────────────────────────────────────
    // Any authenticated user can read their OWN doc (needed for role lookup
    // in AuthContext without a circular dependency).
    // Only existing super-admins can write / read others' docs.
    match /super_admin_users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── user_roles ───────────────────────────────────────────────────────────
    // Any authenticated user can read their own role doc.
    // Only super-admins can create/update role docs.
    match /user_roles/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── users (extended profiles) ────────────────────────────────────────────
    // Users can read/write their own profiles. Super admins can read/write all.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read, write: if isSuperAdmin();
    }

    // ── global_announcements ─────────────────────────────────────────────────
    match /global_announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── system_settings ──────────────────────────────────────────────────────
    match /system_settings/{settingsId} {
      allow read, write: if isSuperAdmin();
    }

    // ── audit_logs ───────────────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    // ── schools (multi-tenant) ───────────────────────────────────────────────
    // Super-admins have full access to all schools.
    // School members (admin/teacher/student) can read/write their own school.
    match /schools/{schoolId} {
      allow read, write: if isSuperAdmin();
      allow read, write: if isSchoolMember(schoolId);

      match /students/{studentId} {
        allow read: if true;
        allow write: if isSuperAdmin() || isSchoolAdmin(schoolId);
      }

      match /{subcollection}/{document=**} {
        allow read, write: if isSuperAdmin();
        allow read, write: if isSchoolMember(schoolId);
      }
    }
  }
}
