{
  "name": "idps-schools-monorepo",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile/student",
    "apps/mobile/teacher"
  ],
  "dependencies": {
    "patch-package": "^8.0.1"
  },
  "scripts": {
    "postinstall": "patch-package",
    "predev": "node scripts/clear-expo-cache.mjs",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=educational-erp-web",
    "dev:mobile": "turbo dev --filter=erp-school-app --filter=idps-management-erp",
    "dev:student": "npm run dev:all --workspace=erp-school-app",
    "dev:student:native": "npm run dev:native --workspace=erp-school-app",
    "dev:teacher": "npm run dev:all --workspace=idps-management-erp",
    "ios": "turbo ios",
    "android": "turbo android"
  },
  "devDependencies": {
    "turbo": "^2.9.18"
  },
  "packageManager": "npm@10.9.0"
}
